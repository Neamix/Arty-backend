{
  "permissions": {
    "allow": [
      "PowerShell(php artisan --version)",
      "PowerShell(composer require laravel/passport laravel/socialite --no-interaction 2>&1)",
      "PowerShell(php artisan vendor:publish --tag=modules-config --force --no-interaction 2>&1)",
